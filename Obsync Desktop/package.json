{
  "name": "obsync",
  "version": "1.0.0",
  "description": "Sync your Obsidian vaults with GitHub",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "cls && npm run build && concurrently --kill-others-on-fail \"tsc -w -p tsconfig.main.json\" \"tsc -w -p tsconfig.renderer.json\" \"electron .\"",
    "build": "cls && tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "start": "cls && npm run build && electron .",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/crypto-js": "^4.2.2",
    "@types/electron": "^1.6.10",
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "typescript": "^5.3.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.0",
    "p-limit": "^3.1.0",
    "simple-git": "^3.27.0",
    "webdav": "^5.9.0"
  }
}
