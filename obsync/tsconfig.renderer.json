    "lib": ["ES2020", "DOM"],
    "module": "ES2020",
    "moduleResolution": "node",
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/renderer/**/*", "src/models/**/*", "src/config/**/*"]
}
