# Google OAuth Credentials
# You can get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Dropbox Credentials (Optional)
DROPBOX_CLIENT_ID=your_dropbox_id
DROPBOX_CLIENT_SECRET=your_dropbox_secret

# OneDrive Credentials (Optional)
ONEDRIVE_CLIENT_ID=your_onedrive_id
ONEDRIVE_CLIENT_SECRET=your_onedrive_secret
